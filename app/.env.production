# Production Environment Configuration
NODE_ENV=production
PORT=5000
HOST=0.0.0.0

# Frontend URL (replace with your production domain)
FRONTEND_URL=https://your-domain.com

# Database Configuration (replace with production database)
DATABASE_URL=postgresql://prod_user:secure_password@prod-db-host:5432/taskflow_prod
DB_HOST=prod-db-host
DB_PORT=5432
DB_NAME=taskflow_prod
DB_USER=prod_user
DB_PASS=secure_password

# Redis Configuration (replace with production Redis)
REDIS_URL=redis://prod-redis-host:6379
REDIS_HOST=prod-redis-host
REDIS_PORT=6379

# JWT Configuration (MUST be changed in production)
JWT_SECRET=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING_AT_LEAST_32_CHARS_LONG
JWT_EXPIRES_IN=24h
REFRESH_TOKEN_SECRET=CHANGE_THIS_TO_ANOTHER_SECURE_RANDOM_STRING

# Email Configuration (configure with real SMTP)
SMTP_HOST=smtp.yourdomain.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your-smtp-password
FROM_EMAIL=noreply@yourdomain.com

# OpenAI Configuration (add real API key if using AI features)
OPENAI_API_KEY=sk-your-real-openai-api-key-here

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_PATH=/app/uploads/

# Security (stronger in production)
BCRYPT_ROUNDS=14
SESSION_SECRET=CHANGE_THIS_TO_A_SECURE_RANDOM_SESSION_SECRET

# Rate Limiting (stricter in production)
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=50

# Logging (detailed logging in production)
LOG_LEVEL=warn
LOG_FILE=/app/logs/app.log

# Additional Security Headers
CORS_ORIGIN=https://your-domain.com
SECURE_HEADERS=true
FORCE_HTTPS=true